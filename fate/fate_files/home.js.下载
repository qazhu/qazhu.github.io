        //加好友
        clickFriend:function() {
            var _this = this;
            
			$(document).on("click", "[f='but_add_friend']", function () {
                _this.obj_id = $(this).attr('id');
                
                var check_login = _this.checkLogin();
                if (check_login == false) {
