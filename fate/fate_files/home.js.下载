				if (typeof (type) == "undefined") {
					type = "add";
				}
				if (type == "add") {
					OEUI.modal.info({
						title: '温馨提示',
						text: '将TA屏蔽后，TA不能再对你发起任何互动，TA将进入你的黑名单',
