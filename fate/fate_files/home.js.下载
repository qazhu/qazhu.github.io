        sendBlack:function(type) {
            var _this = this;
            
            $.ajax({
				type: "POST",
				url: _ROOT_PATH+"index.php?c=home",
				cache: false,
				data: {
					a: "doblack", homeuid: _this.home_uid, type: type
				},
				dataType: "json",
				success: function (data) {
					var response = data.response;
					var result = data.result;
					if (response == "1") {
						if (type == "add") {
							OEUI.message.msg({
								text: '屏蔽成功'
							});
						}
						else {
							OEUI.message.msg({
								text: '已取消屏蔽'
							});
						}
						setTimeout(function () {
							window.location.reload();
						}, 600);
					}
