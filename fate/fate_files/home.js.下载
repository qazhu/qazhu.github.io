		//弹出查看支付
		openViewPay: function (fee) {
            var _this = this;
            fee = parseFloat(fee);
            $("#fee_tips").html(fee);
            
            var login_remain = parseFloat($("#login_remain_money").val());
            if (login_remain >= fee) {
                //弹出选择
                _this.viewpay_dialog = OEUI.modal.dialog({
                    el:'#viewpay_dialog',
                    type: 'custom'
                });
                return false;
            }
            _this.sendPay();
